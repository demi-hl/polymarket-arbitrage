{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dashboard",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "3000"],
      "port": 3000,
      "cwd": "agents/polymarket-arbitrage-bot"
    },
    {
      "name": "api-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["polymarket.js", "server"],
      "port": 3001
    },
    {
      "name": "gpu-worker",
      "runtimeExecutable": "python",
      "runtimeArgs": ["gpu-worker/server.py"],
      "port": 8899
    }
  ]
}
